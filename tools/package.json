{
  "name": "mmorpg-tools",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build-sprite-atlas": "node ./build-sprite-atlas.js",
    "proto:generate": "mkdir -p ../multiplayer/mp-client/src/proto/generated && grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=../multiplayer/mp-client/src/proto/generated --ts_proto_opt=esModuleInterop=true,env=browser,forceLong=bigint,oneof=unions-value,outputServices=none,outputJsonMethods=false ../multiplayer/proto/network.proto --proto_path=../multiplayer/proto",
    "client-simulator": "pnpm run proto:generate && node --import tsx ./client-simulator.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@jsquash/oxipng": "^2.3.0",
    "fflate": "^0.8.2",
    "fluent-ffmpeg": "^2.1.3",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "grpc-tools": "^1.13.1",
    "ts-proto": "^2.11.5",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "grpc-tools",
      "sharp"
    ]
  }
}
